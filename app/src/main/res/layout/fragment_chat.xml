<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_background"
    android:fitsSystemWindows="true">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/input_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/input_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_input_bar"
        android:elevation="8dp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_draw"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_brush"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_draw" />

        <EditText
            android:id="@+id/edit_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_edit_pill"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:hint="@string/hint_message"
            android:textColorHint="@color/hint_text"
            android:maxLines="4"
            android:imeOptions="actionSend"
            android:inputType="textShortMessage|textMultiLine|textCapSentences" />

        <!-- Groupe enregistrement : caché tant qu'on n'enregistre pas -->
        <View
            android:id="@+id/rec_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/dot_recording"
            android:visibility="gone" />

        <TextView
            android:id="@+id/rec_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="0:00"
            android:textColor="@color/bubble_received_text"
            android:textSize="14sp"
            android:visibility="gone" />

        <ch.heigvd.iict.dma.labo5.ui.WaveformView
            android:id="@+id/waveform_live"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_audio"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_mic"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_audio" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_send" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>